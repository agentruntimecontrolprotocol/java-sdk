// Heartbeat + ack cadence (dark variant).

digraph HeartbeatAck {
  rankdir=LR;
  bgcolor="transparent";
  compound=true;
  fontname="Helvetica";
  splines=spline;
  nodesep=0.34;
  ranksep=0.70;
  pad="0.35,0.25";

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#334155",
    color="#475569",
    fontname="Helvetica",
    fontsize=11,
    fontcolor="#F1F5F9",
    margin="0.22,0.11",
    penwidth=1.0
  ];
  edge [
    fontname="Helvetica",
    fontsize=9,
    fontcolor="#94A3B8",
    color="#64748B",
    penwidth=1.1,
    arrowsize=0.75,
    arrowhead=vee
  ];

  subgraph cluster_client {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>Client</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#0F172A";
    color="#334155";
    fontname="Helvetica";
    fontcolor="#94A3B8";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    ClientApp [
      label=<<FONT POINT-SIZE="12"><B>ArcpClient</B></FONT>>,
      fillcolor="#3B82F6", color="#2563EB",
      fontcolor="white", penwidth=1.4
    ];
    ClientSched [
      label=<<FONT POINT-SIZE="10">ScheduledExecutorService</FONT><BR/><FONT POINT-SIZE="8" COLOR="#64748B">ack + watchdog</FONT>>,
      shape=cylinder, fillcolor="#1E293B"
    ];
  }

  subgraph cluster_runtime {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>Runtime</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#1E293B";
    color="#334155";
    fontname="Helvetica";
    fontcolor="#94A3B8";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    SessionLoop [
      label=<<FONT POINT-SIZE="12"><B>SessionLoop</B></FONT>>,
      fillcolor="#F59E0B", color="#D97706",
      fontcolor="white", penwidth=1.4
    ];
    HBTracker [label="HeartbeatTracker"];
    RuntimeSched [
      label=<<FONT POINT-SIZE="10">ScheduledExecutorService</FONT><BR/><FONT POINT-SIZE="8" COLOR="#64748B">ping tick</FONT>>,
      shape=cylinder, fillcolor="#1E293B"
    ];
  }

  edge [color="#94A3B8", penwidth=1.2];
  RuntimeSched -> SessionLoop [label="tick(interval)"];
  SessionLoop -> ClientApp [label="session.ping\n§6.4"];
  ClientApp -> SessionLoop [label="session.pong\n§6.4"];

  edge [color="#475569", penwidth=1.0];
  ClientSched -> ClientApp [label="rate-limited ack\n§6.5"];
  ClientApp -> SessionLoop [label="session.ack { last_processed_seq }\n§6.5"];
  SessionLoop -> HBTracker [label="onInbound"];

  edge [style=dashed, color="#F472B6", penwidth=1.1, constraint=false];
  HBTracker -> SessionLoop [
    label=<<FONT COLOR="#F472B6">HEARTBEAT_LOST after 2 misses</FONT>>,
    fontsize=9
  ];
}
