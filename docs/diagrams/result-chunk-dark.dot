// result_chunk reassembly sequence (dark variant).

digraph ResultChunk {
  rankdir=LR;
  bgcolor="transparent";
  compound=true;
  fontname="Helvetica";
  splines=spline;
  nodesep=0.36;
  ranksep=0.65;
  pad="0.35,0.25";

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#334155",
    color="#475569",
    fontname="Helvetica",
    fontsize=11,
    fontcolor="#F1F5F9",
    margin="0.22,0.11",
    penwidth=1.0
  ];
  edge [
    fontname="Helvetica",
    fontsize=9,
    fontcolor="#94A3B8",
    color="#64748B",
    penwidth=1.1,
    arrowsize=0.75,
    arrowhead=vee
  ];

  Agent [
    label=<<FONT POINT-SIZE="12"><B>Agent</B></FONT>>,
    fillcolor="#3B82F6", color="#2563EB",
    fontcolor="white", penwidth=1.4
  ];

  subgraph cluster_pipe {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>Wire</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#0F172A";
    color="#334155";
    fontname="Helvetica";
    fontcolor="#94A3B8";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    ResultChunkEnvelope [label="result_chunk\n{ result_id, chunk_seq, more }"];
    JobResult [label="job.result\n{ final_status, result_id }"];
  }

  subgraph cluster_client {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>Client</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#1E293B";
    color="#334155";
    fontname="Helvetica";
    fontcolor="#94A3B8";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    ResultStream [
      label=<<FONT POINT-SIZE="12"><B>ResultStream</B></FONT>>,
      fillcolor="#F59E0B", color="#D97706",
      fontcolor="white", penwidth=1.4
    ];
    Sink [
      label=<<FONT POINT-SIZE="10">Sink</FONT><BR/><FONT POINT-SIZE="8" COLOR="#64748B">OutputStream</FONT>>,
      shape=cylinder, fillcolor="#1E293B"
    ];
  }

  edge [color="#94A3B8", penwidth=1.2];
  Agent -> ResultChunkEnvelope [label="emit chunk_seq=0..N-1\n§8.4"];
  ResultChunkEnvelope -> ResultStream [label="accept(chunk)"];
  Agent -> JobResult [label="JobOutcome.Success.streamed\n§8.4"];

  edge [color="#475569", penwidth=1.0];
  ResultStream -> Sink [label="decoded bytes"];

  edge [style=dashed, color="#F472B6", penwidth=1.1, constraint=false];
  ResultStream -> ResultStream [
    label=<<FONT COLOR="#F472B6">out-of-order buffered<BR/>duplicate rejected</FONT>>,
    fontsize=9
  ];
}
